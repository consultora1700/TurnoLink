// ============ GASTRO SALON ============

enum TableSessionStatus {
  OCCUPIED
  ORDERING
  BILL_REQUESTED
  PAYMENT_ENABLED
  WAITING_PAYMENT
  PAID
  CLOSED
}

model TableSession {
  id          String             @id @default(uuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tableNumber Int
  status      TableSessionStatus @default(OCCUPIED)
  sessionWord String?            // Keyword shown to first scanner; others must enter it to join
  openedAt    DateTime           @default(now())
  closedAt    DateTime?
  totalAmount Decimal?           @db.Decimal(10, 2)
  tipAmount   Decimal?           @db.Decimal(10, 2)
  tipType     String?            // "percentage" | "fixed" | "none"
  paymentId     String?            // MP payment reference
  paymentMethod String?            // "cash" | "card" | "mercadopago"
  review        String?            // Customer review/feedback text
  comensalEmail String?            // Email captured at farewell screen
  comensalName  String?            // Name captured at farewell screen
  waiterId      String?            // Employee (mozo) attending this table
  waiter        Employee?          @relation(fields: [waiterId], references: [id])
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // Relations
  orders      TableSessionOrder[]
  comandas    KitchenComanda[]

  @@index([tenantId, status])
  @@index([tenantId, tableNumber])
  @@index([waiterId])
  @@map("table_sessions")
}

model TableSessionOrder {
  id             String       @id @default(uuid())
  tableSessionId String
  tableSession   TableSession @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  orderNumber    Int          // Sequential within session (1, 2, 3...)
  items          Json         // [{productId, name, quantity, price, options, notes}]
  subtotal       Decimal      @db.Decimal(10, 2)
  status         String       @default("PENDING") // PENDING, CONFIRMED, PREPARING, READY, DELIVERED
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Kitchen comanda relations
  comandas       KitchenComanda[]

  @@index([tableSessionId])
  @@map("table_session_orders")
}

// ============ KITCHEN COMANDAS ============

model KitchenStation {
  id            String    @id @default(uuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String    // "Cocina Caliente", "Barra", "Postres"
  displayName   String    // What prints on ticket header
  printerId     String?   // Unique printer identifier (set by print agent)
  printerName   String?   // Human-readable: "Epson TM-T20III Cocina"
  isActive      Boolean   @default(true)
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  products      Product[]
  comandas      KitchenComanda[]

  @@index([tenantId, isActive])
  @@map("kitchen_stations")
}

model KitchenComanda {
  id                    String             @id @default(uuid())
  tenantId              String
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stationId             String
  station               KitchenStation     @relation(fields: [stationId], references: [id], onDelete: Cascade)
  tableSessionId        String
  tableSession          TableSession       @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  tableSessionOrderId   String
  sessionOrder          TableSessionOrder  @relation(fields: [tableSessionOrderId], references: [id], onDelete: Cascade)
  tableNumber           Int
  orderNumber           Int
  items                 Json               // [{name, quantity, notes, options}]
  status                String             @default("PENDING") // PENDING, PRINTED, PRINT_FAILED, ACCEPTED, PREPARING, READY, CANCELLED
  printAttempts         Int                @default(0)
  printedAt             DateTime?
  printError            String?
  acceptedAt            DateTime?
  startedAt             DateTime?
  readyAt               DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@unique([tableSessionOrderId, stationId])
  @@index([tenantId, stationId, status])
  @@index([tableSessionId])
  @@index([status, createdAt])
  @@map("kitchen_comandas")
}

model PrintAgent {
  id                String    @id @default(uuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String    @default("Print Agent")
  token             String    @unique // 48-char hex, used for initial pairing → JWT exchange
  isActive          Boolean   @default(true)
  lastSeenAt        DateTime?
  lastIp            String?
  version           String?
  detectedPrinters  Json?     // Array of { id, name, type, address?, online } reported by agent
  printersUpdatedAt DateTime? // When the agent last reported its printer list
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId, isActive])
  @@map("print_agents")
}

// ===========================================
// RENTAL MANAGEMENT (INMOBILIARIAS)
// ===========================================

// ============ PROPERTY OWNERS (PROPIETARIOS) ============

model PropertyOwner {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  email       String?
  cuitCuil    String?
  cbu         String?
  bankName    String?
  alias       String?
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties    RentalProperty[]
  liquidations  OwnerLiquidation[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("property_owners")
}

// ============ RENTAL PROPERTIES (INMUEBLES) ============

model RentalProperty {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           PropertyOwner @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  name            String
  propertyType    String   @default("departamento") // departamento, casa, local, oficina, ph, cochera, terreno, galpon
  address         String
  city            String?
  neighborhood    String?
  floor           String?
  unit            String?
  area            Decimal? @db.Decimal(10, 2)
  rooms           Int?
  bathrooms       Int?

  commissionType  String   @default("percentage") // percentage, fixed
  commissionValue Decimal  @db.Decimal(10, 2) @default(5)

  status          String   @default("available") // available, rented, maintenance, reserved
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contracts       RentalContract[]
  expenses        PropertyExpenseRecord[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([ownerId])
  @@index([productId])
  @@map("rental_properties")
}

// ============ RENTAL TENANTS (INQUILINOS) ============

model RentalTenant {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  dni             String?
  phone           String?
  email           String?
  employer        String?
  monthlyIncome   Decimal? @db.Decimal(10, 2)
  emergencyContact    String?
  emergencyPhone      String?
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contracts       RentalContract[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("rental_tenants")
}

// ============ RENTAL CONTRACTS (CONTRATOS DE ALQUILER) ============

model RentalContract {
  id                  String   @id @default(uuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propertyId          String
  property            RentalProperty @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  rentalTenantId      String
  rentalTenant        RentalTenant @relation(fields: [rentalTenantId], references: [id], onDelete: Restrict)

  contractNumber      String?
  startDate           DateTime
  endDate             DateTime

  monthlyRent         Decimal  @db.Decimal(10, 2)
  currency            String   @default("ARS")
  securityDeposit     Decimal? @db.Decimal(10, 2)

  adjustmentIndex     String?  @default("ICL") // ICL, IPC, custom, none
  adjustmentFrequency Int?     @default(12) // months
  customAdjustmentDesc String?

  commissionType      String   @default("percentage") // percentage, fixed
  commissionValue     Decimal  @db.Decimal(10, 2) @default(5)

  guaranteeType       String?  // propietaria, caucion, bancaria, personal, seguro_caucion

  status              String   @default("active") // active, expired, terminated, draft
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  payments            RentalPayment[]
  adjustments         ContractAdjustment[]
  expenses            PropertyExpenseRecord[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([propertyId])
  @@index([rentalTenantId])
  @@index([tenantId, endDate])
  @@map("rental_contracts")
}

// ============ RENTAL PAYMENTS (PAGOS DE ALQUILER) ============

model RentalPayment {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractId      String
  contract        RentalContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  periodMonth     Int
  periodYear      Int

  expectedAmount  Decimal  @db.Decimal(10, 2)
  paidAmount      Decimal  @db.Decimal(10, 2) @default(0)
  coveragePercent Decimal  @db.Decimal(5, 2)  @default(0)

  paymentMethod   String?  // transferencia, efectivo, cheque, deposito
  paymentDate     DateTime?
  receiptNumber   String?

  status          String   @default("pending") // pending, partial, paid, overdue
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([contractId, periodMonth, periodYear])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([contractId])
  @@index([tenantId, periodYear, periodMonth])
  @@map("rental_payments")
}

// ============ CONTRACT ADJUSTMENTS (ACTUALIZACIONES DE PRECIO) ============

model ContractAdjustment {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractId      String
  contract        RentalContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  effectiveDate   DateTime
  previousAmount  Decimal  @db.Decimal(10, 2)
  newAmount       Decimal  @db.Decimal(10, 2)
  adjustmentPercent Decimal? @db.Decimal(5, 2)

  indexUsed       String?  // ICL, IPC, custom
  indexValue      Decimal? @db.Decimal(10, 4)

  isAutomatic     Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([contractId])
  @@index([contractId, effectiveDate])
  @@map("contract_adjustments")
}

// ============ PROPERTY EXPENSE RECORDS (GASTOS DE INMUEBLE) ============

model PropertyExpenseRecord {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propertyId      String?
  property        RentalProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  contractId      String?
  contract        RentalContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  expenseType     String   // expensas, abl, agua, gas, luz, reparaciones, seguro, impuestos, otros
  description     String?
  amount          Decimal  @db.Decimal(10, 2)
  date            DateTime @default(now())

  paidBy          String   @default("owner") // owner, tenant, shared
  sharedPercent   Decimal? @db.Decimal(5, 2)

  deductFromLiquidation Boolean @default(true)
  liquidationId   String?
  liquidation     OwnerLiquidation? @relation(fields: [liquidationId], references: [id], onDelete: SetNull)

  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([propertyId])
  @@index([contractId])
  @@index([liquidationId])
  @@index([tenantId, date])
  @@map("property_expense_records")
}

// ============ OWNER LIQUIDATIONS (LIQUIDACIONES A PROPIETARIOS) ============

model OwnerLiquidation {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           PropertyOwner @relation(fields: [ownerId], references: [id], onDelete: Restrict)

  periodMonth     Int
  periodYear      Int

  grossCollected  Decimal  @db.Decimal(10, 2)
  commissionAmount Decimal @db.Decimal(10, 2)
  expensesAmount  Decimal  @db.Decimal(10, 2)
  netToPay        Decimal  @db.Decimal(10, 2)

  status          String   @default("draft") // draft, sent, paid
  pdfUrl          String?
  notes           String?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  expenses        PropertyExpenseRecord[]

  @@unique([tenantId, ownerId, periodMonth, periodYear])
  @@index([tenantId])
  @@index([tenantId, periodYear, periodMonth])
  @@index([ownerId])
  @@index([tenantId, status])
  @@map("owner_liquidations")
}

// ===========================================
// DEVELOPMENT PROJECTS (POZO / PREVENTA)
// ===========================================

model DevelopmentProject {
  id                  String   @id @default(uuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  slug                String
  description         String?
  address             String?
  city                String?
  totalUnits          Int      @default(0)

  progressPercent     Int      @default(0)
  status              String   @default("planning") // planning, pre_sale, under_construction, delivered

  targetFundingAmount Decimal? @db.Decimal(12, 2)
  currentFundedAmount Decimal  @db.Decimal(12, 2) @default(0)

  coverImage          String?
  images              String   @default("[]")

  // ── New fields ──
  reservationDays     Int      @default(15)         // days a reservation lasts before auto-expiry
  adjustmentType      String   @default("fixed_usd") // fixed_usd, fixed_ars, cac, uva, dolar_linked
  brochureUrl         String?                        // PDF brochure URL
  videoUrl            String?                        // YouTube/Vimeo URL
  latitude            Decimal? @db.Decimal(10, 7)
  longitude           Decimal? @db.Decimal(10, 7)
  amenities           String   @default("[]")        // JSON array: pileta, sum, gym, seguridad, etc.
  deliveryDate        DateTime?                      // estimated delivery date

  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  milestones          ProjectMilestone[]
  units               ProjectUnit[]
  investments         ProjectInvestment[]
  paymentPlans        PaymentPlan[]
  documents           ProjectDocument[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("development_projects")
}

model ProjectMilestone {
  id              String    @id @default(uuid())
  projectId       String
  project         DevelopmentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  progressPercent Int       @default(0)
  targetDate      DateTime?
  completionDate  DateTime?
  photos          String    @default("[]")
  order           Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([projectId])
  @@map("project_milestones")
}

model ProjectUnit {
  id              String   @id @default(uuid())
  projectId       String
  project         DevelopmentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  unitIdentifier  String
  unitType        String   @default("2amb") // monoambiente, 1amb, 2amb, 3amb, local, cochera, baulera
  floor           String?
  orientation     String?
  area            Decimal? @db.Decimal(10, 2)
  supCubierta     Decimal? @db.Decimal(10, 2)  // covered area (distinct from total area)
  price           Decimal? @db.Decimal(12, 2)
  currency        String   @default("USD")
  status          String   @default("available") // available, reserved, sold, escriturada
  floorPlanUrl    String?  // URL to unit floor plan image/PDF

  // ── Reservation fields ──
  reservedAt              DateTime?
  reservationExpiresAt    DateTime?
  reservedByName          String?
  reservedByPhone         String?
  reservedByEmail         String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  investments     ProjectInvestment[]
  documents       ProjectDocument[]

  @@unique([projectId, unitIdentifier])
  @@index([projectId])
  @@index([projectId, status])
  @@index([status, reservationExpiresAt])
  @@map("project_units")
}

model ProjectInvestment {
  id              String   @id @default(uuid())
  projectId       String
  project         DevelopmentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  unitId          String?
  unit            ProjectUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  investorName    String
  investorDni     String?
  investorPhone   String?
  investorEmail   String?

  totalAmount     Decimal  @db.Decimal(12, 2)
  paidAmount      Decimal  @db.Decimal(12, 2) @default(0)
  currency        String   @default("USD")
  totalInstallments Int    @default(1)

  // ── Payment plan & adjustment ──
  paymentPlanId   String?
  paymentPlan     PaymentPlan? @relation(fields: [paymentPlanId], references: [id], onDelete: SetNull)
  downPaymentAmount Decimal? @db.Decimal(12, 2)
  adjustmentType  String?   // override per investment: fixed_usd, cac, uva, dolar_linked

  status          String   @default("active") // active, completed, cancelled, defaulted
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments        InvestmentPayment[]
  documents       ProjectDocument[]

  @@index([projectId])
  @@index([unitId])
  @@index([projectId, status])
  @@map("project_investments")
}

model InvestmentPayment {
  id              String    @id @default(uuid())
  investmentId    String
  investment      ProjectInvestment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  installmentNumber Int
  dueDate         DateTime
  amount          Decimal   @db.Decimal(12, 2)
  paidAmount      Decimal   @db.Decimal(12, 2) @default(0)
  paidDate        DateTime?
  paymentMethod   String?   // transferencia, efectivo, cheque
  status          String    @default("pending") // pending, paid, overdue, partial
  notes           String?

  // ── Adjustment & receipt ──
  adjustedAmount  Decimal?  @db.Decimal(12, 2) // amount after CAC/UVA adjustment
  adjustmentIndex String?                       // index value used (e.g. "CAC Mar 2026: 1.045")
  receiptUrl      String?                       // payment receipt file URL

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([investmentId, installmentNumber])
  @@index([investmentId])
  @@index([investmentId, status])
  @@index([dueDate, status])
  @@map("investment_payments")
}

// ── Payment plans for development projects ──
model PaymentPlan {
  id                 String   @id @default(uuid())
  projectId          String
  project            DevelopmentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name               String   // e.g. "Plan Contado", "Plan 12 Cuotas", "Plan Inversor"
  downPaymentPercent Int      @default(30) // anticipo percentage (0-100)
  installments       Int      @default(12) // number of monthly installments after down payment
  discountPercent    Decimal  @db.Decimal(5, 2) @default(0) // discount for this plan (e.g. 10% contado)
  adjustmentType     String   @default("fixed_usd") // fixed_usd, fixed_ars, cac, uva, dolar_linked
  description        String?
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  investments        ProjectInvestment[]

  @@index([projectId])
  @@map("payment_plans")
}

// ── Documents for projects, units, and investments ──
model ProjectDocument {
  id              String    @id @default(uuid())
  projectId       String
  project         DevelopmentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  unitId          String?
  unit            ProjectUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  investmentId    String?
  investment      ProjectInvestment? @relation(fields: [investmentId], references: [id], onDelete: SetNull)
  name            String
  type            String    @default("otro") // reserva, boleto, cesion, escritura, plano, otro
  fileUrl         String
  createdAt       DateTime  @default(now())

  @@index([projectId])
  @@index([unitId])
  @@index([investmentId])
  @@map("project_documents")
}

// ============ CRM LEADS (INMOBILIARIAS) ============

model Lead {
  id              String    @id @default(uuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Contact info
  name            String
  phone           String?
  email           String?
  dni             String?

  // Lead source & context
  source          String    @default("manual") // manual, whatsapp, web, referido, portal
  sourceDetail    String?   // e.g. "ZonaProp", "Referido de Juan", property ID

  // Pipeline
  stage           String    @default("nuevo") // nuevo, contactado, visita, oferta, reserva, escritura, cerrado, perdido
  priority        String    @default("media") // baja, media, alta

  // What they're looking for
  interestType    String?   // compra, alquiler, inversion
  interestDetail  String?   // "2amb Palermo hasta USD 120k"
  productId       String?   // linked property if specific interest
  unitId          String?   // linked development unit if specific interest
  budget          Decimal?  @db.Decimal(12, 2)
  budgetCurrency  String?   @default("USD")

  // Assignment
  assignedTo      String?   // employee/agent name

  // Follow-up
  lastContactAt   DateTime?
  nextFollowUpAt  DateTime?
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, source])
  @@index([tenantId, assignedTo])
  @@index([tenantId, nextFollowUpAt])
  @@map("leads")
}

// ============ PROPERTY DEPOSITS / SEÑAS (INMOBILIARIAS) ============

model PropertyDeposit {
  id              String    @id @default(uuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  productId       String    // the property (Product)

  // Buyer info
  buyerName       String
  buyerDni        String?
  buyerPhone      String?
  buyerEmail      String?

  // Deposit details
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("USD")
  paidAt          DateTime?
  paymentMethod   String?   // transferencia, efectivo, cheque
  receiptUrl      String?

  // Terms
  expiresAt       DateTime? // deadline to sign boleto
  propertyPrice   Decimal?  @db.Decimal(12, 2) // agreed sale price
  notes           String?

  // Status
  status          String    @default("pending") // pending, paid, expired, refunded, converted (→ boleto)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([productId])
  @@map("property_deposits")
}

// ============ GUARANTEE RECORDS (INMOBILIARIAS) ============

model GuaranteeRecord {
  id              String    @id @default(uuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contractId      String    // linked to RentalContract

  // Guarantee details
  guaranteeType   String    // propietaria, caucion, bancaria, personal, seguro_caucion
  provider        String?   // company name (e.g. "Porto Seguros", bank name)
  policyNumber    String?   // policy or certificate number

  // Guarantor info (for personal/propietaria)
  guarantorName   String?
  guarantorDni    String?
  guarantorPhone  String?
  guarantorEmail  String?
  guarantorAddress String?

  // Coverage
  coverageAmount  Decimal?  @db.Decimal(12, 2)
  currency        String    @default("ARS")

  // Dates
  startDate       DateTime?
  expirationDate  DateTime?

  // Documents
  documentUrl     String?   // uploaded guarantee document

  // Status
  status          String    @default("active") // active, expired, released, claimed
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([contractId])
  @@index([tenantId, status])
  @@index([tenantId, expirationDate])
  @@map("guarantee_records")
}

// ============ DOCUMENT TEMPLATES (INMOBILIARIAS) ============

model DocumentTemplate {
  id              String    @id @default(uuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String    // "Contrato de alquiler", "Boleto de reserva"
  category        String    @default("contrato") // contrato, recibo, boleto, autorizacion, liquidacion, otro
  description     String?

  // Template content — HTML with {{variable}} placeholders
  htmlContent     String    @db.Text

  // Available variables for this template (JSON array of { key, label, source })
  variables       String    @default("[]") @db.Text

  isActive        Boolean   @default(true)
  isDefault       Boolean   @default(false) // one default per category per tenant

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, isActive])
  @@map("document_templates")
}
