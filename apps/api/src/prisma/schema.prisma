// ============ AUDIT LOGS ============

model AuditLog {
  id          String        @id @default(uuid())
  timestamp   DateTime      @default(now())
  action      String        // LOGIN, LOGOUT, CREATE, UPDATE, DELETE, PAYMENT, ADMIN_ACTION, etc.
  entityType  String        // User, Tenant, Subscription, Payment, etc.
